<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Task Dashboard</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #f5f7fa, #c3cfe2);
      color: #333;
    }
    .dashboard { display: flex; min-height: 100vh; }
    .sidebar { width: 260px; background: #2f3e46; color: white; padding: 25px; box-sizing: border-box; }
    .sidebar h2 { margin-top: 0; font-size: 24px; }
    .sidebar a { display: block; color: white; text-decoration: none; margin: 12px 0; padding: 8px 10px; border-radius: 8px; background: #4f6f7f; }
    .main { flex: 1; padding: 30px; box-sizing: border-box; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 25px; }
    .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.08); }
    .card h3 { margin: 0 0 8px; font-size: 16px; color: #666; }
    .card p { margin: 0; font-size: 24px; font-weight: bold; color: #222; }
    .task-list { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.08); }
    .alert { background: #ecfdf3; color: #065f46; padding: 12px 14px; border-radius: 8px; margin-bottom: 16px; }
    .btn { display: inline-block; background: #4f46e5; color: white; padding: 10px 14px; border-radius: 8px; text-decoration: none; margin-top: 10px; }
  </style>
</head>
<body>
  <div class="dashboard">
    <aside class="sidebar">
      <h2>Task Manager</h2>
      <p>Welcome, <%= userName || 'User' %></p>
      <a href="/createtask">+ Create Task</a>
      <a href="/viewtask">View Tasks</a>
      <a href="/logout">Logout</a>
    </aside>

    <main class="main">
      <div class="topbar">
        <div>
          <h1>Your Dashboard</h1>
          <p>Manage your tasks easily.</p>
        </div>
        <a class="btn" href="/createtask">Add New Task</a>
      </div>

      <% if (message) { %>
        <div class="alert"><%= message %></div>
      <% } %>

      <div class="cards">
        <div class="card">
          <h3>Total Tasks</h3>
          <p><%= totalTasks || 0 %></p>
        </div>
        <div class="card">
          <h3>Pending</h3>
          <p><%= pendingTasks || 0 %></p>
        </div>
        <div class="card">
          <h3>Completed</h3>
          <p><%= completedTasks || 0 %></p>
        </div>
      </div>

      <section class="task-list">
        <h3><a href="/viewtask" style="text-decoration: none; color: #2f3e46;">Your Tasks</a></h3>
      </section>
    </main>
  </div>
</body>
</html>
